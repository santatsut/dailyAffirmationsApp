{
  "expo": {
    "name": "ChengyuScroll",
    "slug": "Daily-Verse",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/ChengyuScroll.png",
    "scheme": "dailyverse",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/ChengyuScroll.png",
        "backgroundImage": "./assets/images/ChengyuScroll.png",
        "monochromeImage": "./assets/images/ChengyuScroll.png"
      },
      "permissions": ["VIBRATE"],
      "predictiveBackGestureEnabled": false,
      "package": "com.SerenSoul.ChengyuScroll",
      "versionCode": 1
    },
    "platforms": [
      "android",
      "web"
    ],
    "web": {
      "output": "static",
      "favicon": "./assets/images/ChengyuScroll.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/ChengyuScroll.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0f118e2f-79ae-42ff-9648-f9de4a5f951b"
      }
    },
    "owner": "serensoul"
  }
}
